# Backend Environment Variables

## Database Configuration
MONGO_URI=mongodb://your_mongodb_connection_string

## JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

## Email Configuration (Gmail)
EMAIL_USER=your_gmail_email@gmail.com
EMAIL_PASSWORD=your_app_password_from_gmail

# To get Gmail App Password:
# 1. Go to myaccount.google.com
# 2. Select "Security" on the left
# 3. Enable "2-Step Verification" if not already enabled
# 4. Search for "App passwords"
# 5. Select "Mail" and "Windows Computer"
# 6. Copy the generated 16-character password and paste it here

## Server Configuration
PORT=1337
NODE_ENV=development

# Frontend Environment Variables (.env in frontend folder)
VITE_API_URL=http://localhost:1337

# For production:
VITE_API_URL=https://your_backend_url.com
