# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# 🔐 SECURITY: Environment variables (NEVER commit secrets)
.env
.env.local
.env.*.local

# 🔐 SECURITY: Sensitive files
*.pem
*.key
*.crt
secrets.json

# dependencies
/node_modules

# Build output
/build

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*

# Uploads (if contains sensitive files)
/uploads/*
!/.uploads/.gitkeep