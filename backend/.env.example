# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - only commit .env.example

# MongoDB Connection String
# For local: mongodb://localhost:27017/music_website
# For Atlas: mongodb+srv://username:password@cluster.mongodb.net/music_website
MONGO_URI=mongodb://localhost:27017/music_website

# JWT Secret Key for authentication tokens
# Generate a random string (min 32 characters recommended)
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars

# Gmail Configuration for sending OTP emails
# Use Gmail account email address
EMAIL_USER=your_email@gmail.com

# Gmail App Password (NOT your regular password!)
# Get from: https://myaccount.google.com → Security → App Passwords
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Backend Server Port
PORT=1337
